// =============================================================================
// RIBO — Relational Database Schema
// Compatible with Odoo res.partner conventions where noted.
// =============================================================================


// =============================================================================
// GEOGRAPHIC TABLES
// Following the structure from kidino/SQL-Countries-States-Provinces
// =============================================================================

Table countries {
  country_id  int          [pk, not null]
  ccode       char(2)      [not null, unique, note: 'ISO 3166-1 alpha-2 (e.g. AR, US)']
  name        varchar(255) [not null]
  phone_code  varchar(10)  [note: 'International dial prefix (e.g. +54)']

  Note: 'Countries catalogue. Mirrors Odoo res.country. Stores ISO 3166-1 alpha-2 codes and full country names.'
}

Table states_provinces {
  state_id   int          [pk, increment, not null]
  country_id int          [not null, note: 'FK → countries']
  name       varchar(255) [not null]
  code       varchar(10)  [note: 'ISO 3166-2 subdivision code (e.g. BA, CA)']

  indexes {
    country_id [name: 'idx_states_country']
  }

  Note: 'States / provinces within a country. Mirrors Odoo res.country.state. Each record belongs to exactly one country.'
}

Table cities {
  city_id  int          [pk, increment, not null]
  state_id int          [not null, note: 'FK → states_provinces']
  name     varchar(255) [not null]
  zip_code varchar(20)  [note: 'Postal / ZIP code for the city']

  indexes {
    state_id [name: 'idx_cities_state']
  }

  Note: 'Cities / municipalities within a state or province. Extends the kidino model with an explicit city level.'
}


// =============================================================================
// KYC (KNOW YOUR CUSTOMER)
// =============================================================================

Table kyc_statuses {
  kyc_status_id  tinyint     [pk, increment, not null]
  code           varchar(30) [not null, unique, note: 'Machine-readable key (e.g. in_progress)']
  label          varchar(60) [not null, note: 'Human-readable label (e.g. In Progress)']
  description    text
  is_terminal    boolean     [not null, default: false, note: 'TRUE for final states (approved / rejected)']

  Note: 'Catalogue of possible KYC review statuses for a client. Kept as a separate table so statuses can be extended without schema changes.'
}


// =============================================================================
// CLIENT TIERS
// Risk / commercial segmentation applied to each client by RIBO credit team.
// Sourced from the Odoo res.partner field "Tipo de cliente".
// Kept as a nomenclator so new tiers can be added without schema changes.
// =============================================================================

Table client_tiers {
  tier_id         tinyint     [pk, increment, not null]
  code            varchar(30) [not null, unique, note: 'Machine key e.g. classic, lista_negra']
  label           varchar(60) [not null, note: 'Display name e.g. Classic']
  description     text
  credit_eligible boolean     [not null, default: true, note: 'Credit policy flag — FALSE for tiers blocked from receiving new credit (e.g. lista_negativa)']
  sort_order      tinyint     [not null, default: 0]
  is_active       boolean     [not null, default: true]

  Note: 'Risk / commercial segmentation applied to each client by RIBO credit team. Sourced from Odoo res.partner field "Tipo de cliente".'
}

Table document_types {
  document_type_id  tinyint     [pk, increment, not null]
  code              varchar(20) [not null, unique, note: 'e.g. DNI, PASSPORT, RUC']
  label             varchar(60) [not null]

  Note: 'Document types accepted as identity proof (DNI, passport, RUC, CUIT, etc.).'
}


// =============================================================================
// CLIENTS
// Represents natural or legal persons that operate as clients in RIBO.
// Field naming aligned with Odoo res.partner model for easy integration.
// =============================================================================

Table clients {
  client_id  int [pk, increment, not null]

  // Identity fields
  document_type_id          tinyint       [not null, note: 'FK → document_types']
  dni                       varchar(30)   [not null, note: 'Identity document number (DNI / passport / RUC …)']
  first_name                varchar(100)  [note: 'NULL for legal entities']
  last_name                 varchar(100)  [note: 'NULL for legal entities']
  company_name              varchar(255)  [note: 'NULL for natural persons']
  is_company                boolean       [not null, default: false]
  vat                       varchar(30)   [note: 'Tax ID / VAT number (Odoo: partner.vat)']
  gender                    varchar(1)    [note: 'Allowed values: M, F, X']
  birth_date                date
  nationality_id            int           [note: 'FK → countries']

  // Contact fields (aligned with Odoo res.partner)
  email                     varchar(254)
  phone                     varchar(30)   [note: 'Landline (Odoo: partner.phone)']
  mobile                    varchar(30)   [note: 'Mobile (Odoo: partner.mobile)']
  website                   varchar(255)

  // Address fields (Odoo: street, street2, city, state_id, country_id, zip)
  street                    varchar(255)
  street2                   varchar(255)
  city_id                   int           [note: 'FK → cities']
  state_id                  int           [note: 'FK → states_provinces']
  country_id                int           [note: 'FK → countries']
  zip_code                  varchar(20)

  // KYC lifecycle
  kyc_status_id             tinyint       [not null, default: 1, note: 'FK → kyc_statuses. Starts as pending.']
  kyc_reviewed_at           datetime
  kyc_reviewed_by           int           [note: 'FK → users (back-office agent)']
  kyc_notes                 text

  // Commercial tier (Odoo: Tipo de cliente)
  tier_id                   tinyint       [note: 'FK → client_tiers. NULL = not yet classified.']

  // Credit capacity & balances — all monetary values in the currency of the credit product (default PEN)
  credit_limit              decimal(12,2) [note: 'Maximum capital available across all active credit products. Corresponds to "Monto maximo de capital disponible" in Odoo. NULL = not yet assessed; negative = over-limit.']
  available_credit_slots    int           [not null, default: -1, note: 'Odoo: "Créditos activos disponibles". -1 = not computed / unlimited slots. Positive integers indicate remaining slots.']
  monthly_payment_capacity  decimal(12,2) [note: 'Maximum monthly instalment based on income assessment. Corresponds to "Capacidad de pago mensual disponible" in Odoo. NULL / -1 = not yet assessed.']
  current_balance           decimal(12,2) [note: 'Total outstanding principal across all active credits ("Saldo" in Odoo). NULL when no active credits.']
  overdue_balance           decimal(12,2) [note: 'Portion of current_balance that is past due ("Saldo vencido" in Odoo). Non-zero value drives risk alerts.']
  active_credits_count      tinyint       [not null, default: 0, note: 'Number of currently active credit agreements ("Creditos activos" in Odoo). Observed values: 0, 1, 2.']

  // Odoo integration helpers
  odoo_partner_id           int           [unique, note: 'External Odoo res.partner ID']
  ref                       varchar(50)   [note: 'Internal client reference / Odoo ref']

  // Audit
  is_active                 boolean       [not null, default: true]
  created_at                datetime      [not null, default: `now()`]
  updated_at                datetime      [not null, default: `now()`]

  indexes {
    (document_type_id, dni) [unique, name: 'uq_clients_dni']
    kyc_status_id           [name: 'idx_clients_kyc']
    country_id              [name: 'idx_clients_country']
    tier_id                 [name: 'idx_clients_tier']
  }

  Note: 'Main client table. Supports both individual (person) and company clients. Mirrors Odoo res.partner with KYC lifecycle tracking.'
}

Table client_kyc_history {
  history_id     int      [pk, increment, not null]
  client_id      int      [not null, note: 'FK → clients']
  from_status_id tinyint  [note: 'FK → kyc_statuses. NULL on first assignment.']
  to_status_id   tinyint  [not null, note: 'FK → kyc_statuses']
  changed_by     int      [note: 'FK → users']
  notes          text
  changed_at     datetime [not null, default: `now()`]

  indexes {
    client_id [name: 'idx_kyc_history_client']
  }

  Note: 'Audit log of every KYC status transition for a client. Preserves the full history of approvals, rejections and reactivations.'
}


// =============================================================================
// USERS
// Two personas: public (anonymous / token-based) and private (credential-based).
// =============================================================================

Table roles {
  role_id     tinyint     [pk, increment, not null]
  code        varchar(30) [not null, unique, note: 'e.g. admin, agent, client, public']
  label       varchar(60) [not null]
  description text

  Note: 'User roles catalogue. Defines permission levels inside RIBO.'
}

Table users {
  user_id  int     [pk, increment, not null]
  role_id  tinyint [not null, note: 'FK → roles']

  // Identification
  username  varchar(60)  [unique, note: 'NULL for public/guest users']
  email     varchar(254) [unique]

  // Credentials — only for private users (is_public = FALSE)
  password_hash  varchar(255) [note: 'bcrypt / argon2 hash; NULL for public users']
  password_salt  varchar(255) [note: 'Explicit salt if not embedded in hash']

  // Token-based access — primary for public users, optional 2FA for private
  access_token      varchar(512) [note: 'JWT or opaque token']
  refresh_token     varchar(512)
  token_expires_at  datetime

  // Two-factor authentication (private users)
  totp_secret    varchar(64) [note: 'TOTP secret (2FA)']
  is_2fa_enabled boolean     [not null, default: false]

  // Public / private flag
  is_public boolean [not null, default: false, note: 'TRUE = public/guest user identified by token only. FALSE = private user with username + password credentials.']

  // Optional link to a client record (client-portal users)
  client_id int [note: 'FK → clients']

  // Profile
  first_name varchar(100)
  last_name  varchar(100)

  // Audit & status
  is_active           boolean  [not null, default: true]
  last_login_at       datetime
  last_login_ip       varchar(45)  [note: 'Supports IPv4 and IPv6']
  failed_login_count  tinyint      [not null, default: 0]
  locked_until        datetime     [note: 'Brute-force lockout expiry']
  created_at          datetime     [not null, default: `now()`]
  updated_at          datetime     [not null, default: `now()`]

  indexes {
    role_id   [name: 'idx_users_role']
    client_id [name: 'idx_users_client']
  }

  Note: 'Platform users table. Private users (is_public = FALSE) hold a hashed password and a role. Public users (is_public = TRUE) are identified by a token only (e.g. API consumers, guests).'
}


// =============================================================================
// CREDITS
// Models the credit products offered on ribo.pe and web-submitted requests.
// =============================================================================

Table credit_types {
  credit_type_id  tinyint [pk, increment, not null]
  code            varchar(30)   [not null, unique, note: 'Machine key e.g. personal, vehiculo']
  label           varchar(80)   [not null, note: 'Display name e.g. Crédito Personal']
  description     text

  // Amount constraints (in the product's native currency)
  min_amount  decimal(12,2) [note: 'Minimum requestable amount']
  max_amount  decimal(12,2) [note: 'Maximum requestable amount. NULL = no cap.']
  currency    char(3)       [not null, default: 'PEN', note: 'ISO 4217']

  // Installment (cuota) constraints
  min_installments tinyint [note: 'Minimum number of monthly payments']
  max_installments tinyint [note: 'Maximum number of monthly payments']

  // Lifecycle
  is_active   boolean  [not null, default: true]
  sort_order  tinyint  [not null, default: 0, note: 'Display ordering on the website']
  created_at  datetime [not null, default: `now()`]
  updated_at  datetime [not null, default: `now()`]

  Note: 'Nomenclator of credit types available on the RIBO platform. Each row matches one product shown on ribo.pe/peru-productos.'
}

Table credit_request_statuses {
  status_id   tinyint     [pk, increment, not null]
  code        varchar(30) [not null, unique, note: 'e.g. draft, submitted, approved']
  label       varchar(60) [not null]
  description text
  is_terminal boolean     [not null, default: false, note: 'TRUE for final states']

  Note: 'Catalogue of possible statuses for a credit request.'
}

Table credit_requests {
  credit_request_id int [pk, increment, not null]

  // What product was requested
  credit_type_id tinyint [not null, note: 'FK → credit_types']

  // Who made the request — client_id is NULL when the prospect has not been KYC-registered yet
  client_id int [note: 'FK → clients']

  // Prospect contact info captured from the web form
  // (used when client_id is NULL; copied to client record once KYC completes)
  prospect_first_name varchar(100)
  prospect_last_name  varchar(100)
  prospect_email      varchar(254)
  prospect_phone      varchar(30)
  prospect_dni        varchar(30) [note: 'Document number entered on form']

  // Financial terms requested via the simulator / form
  requested_amount decimal(12,2) [not null]
  currency         char(3)       [not null, default: 'PEN', note: 'ISO 4217']
  installments     tinyint       [note: 'Número de cuotas requested']
  monthly_payment  decimal(12,2) [note: 'Estimated cuota shown on the simulator']

  // Approved terms (filled in by an agent after approval)
  approved_amount       decimal(12,2)
  approved_rate_pct     decimal(6,4)  [note: 'Annual effective rate (TEA %)']
  approved_installments tinyint
  approved_at           datetime
  approved_by           int           [note: 'FK → users (agent)']
  disbursed_at          datetime

  // Request lifecycle
  status_id      tinyint     [not null, default: 1, note: 'FK → credit_request_statuses. Starts as draft.']
  source_channel varchar(30) [not null, default: 'web', note: 'e.g. web, typeform, whatsapp, referral']
  utm_source     varchar(100) [note: 'Marketing attribution']
  utm_medium     varchar(100)
  utm_campaign   varchar(100)

  // Free-text fields
  notes            text [note: 'Internal agent notes']
  rejection_reason text [note: 'Populated on rejection']

  // Audit
  submitted_at datetime [note: 'When the web form was sent']
  created_at   datetime [not null, default: `now()`]
  updated_at   datetime [not null, default: `now()`]

  indexes {
    client_id      [name: 'idx_cr_client']
    credit_type_id [name: 'idx_cr_type']
    status_id      [name: 'idx_cr_status']
    submitted_at   [name: 'idx_cr_submitted']
  }

  Note: 'Web credit requests submitted through ribo.pe. Captures every loan / remittance application originating from the website, whether the submitter is already a registered client or a new prospect.'
}

Table credit_request_history {
  history_id        int      [pk, increment, not null]
  credit_request_id int      [not null, note: 'FK → credit_requests']
  from_status_id    tinyint  [note: 'FK → credit_request_statuses. NULL on first assignment.']
  to_status_id      tinyint  [not null, note: 'FK → credit_request_statuses']
  changed_by        int      [note: 'FK → users. NULL = system / webhook.']
  notes             text
  changed_at        datetime [not null, default: `now()`]

  indexes {
    credit_request_id [name: 'idx_crh_request']
  }

  Note: 'Full status-transition audit trail for every credit request.'
}


// =============================================================================
// SESSION MANAGEMENT
// =============================================================================

Table user_sessions {
  session_id         int          [pk, increment, not null]
  user_id            int          [not null, note: 'FK → users']
  refresh_token_hash varchar(255) [not null, note: 'Hashed refresh token (never store plain)']
  issued_at          datetime     [not null, default: `now()`]
  expires_at         datetime     [not null]
  revoked_at         datetime     [note: 'NULL = still valid']
  ip_address         varchar(45)
  user_agent         varchar(512)

  indexes {
    user_id [name: 'idx_sessions_user']
  }

  Note: 'Refresh-token rotation log. Invalidates old tokens and detects token reuse attacks.'
}


// =============================================================================
// RELATIONSHIPS
// =============================================================================

// Geographic
Ref fk_states_country:    states_provinces.country_id   > countries.country_id
Ref fk_cities_state:      cities.state_id               > states_provinces.state_id

// Clients
Ref fk_clients_doc_type:   clients.document_type_id     > document_types.document_type_id
Ref fk_clients_kyc_status: clients.kyc_status_id        > kyc_statuses.kyc_status_id
Ref fk_clients_tier:       clients.tier_id              > client_tiers.tier_id
Ref fk_clients_nationality: clients.nationality_id      > countries.country_id
Ref fk_clients_city:       clients.city_id              > cities.city_id
Ref fk_clients_state:      clients.state_id             > states_provinces.state_id
Ref fk_clients_country:    clients.country_id           > countries.country_id
Ref fk_clients_reviewed_by: clients.kyc_reviewed_by     > users.user_id

// KYC History
Ref fk_kyc_hist_client: client_kyc_history.client_id       > clients.client_id
Ref fk_kyc_hist_from:   client_kyc_history.from_status_id  > kyc_statuses.kyc_status_id
Ref fk_kyc_hist_to:     client_kyc_history.to_status_id    > kyc_statuses.kyc_status_id
Ref fk_kyc_hist_user:   client_kyc_history.changed_by      > users.user_id

// Users
Ref fk_users_role:   users.role_id   > roles.role_id
Ref fk_users_client: users.client_id > clients.client_id

// Credit Requests
Ref fk_cr_credit_type: credit_requests.credit_type_id  > credit_types.credit_type_id
Ref fk_cr_client:      credit_requests.client_id        > clients.client_id
Ref fk_cr_status:      credit_requests.status_id        > credit_request_statuses.status_id
Ref fk_cr_approved_by: credit_requests.approved_by      > users.user_id

// Credit Request History
Ref fk_crh_request: credit_request_history.credit_request_id > credit_requests.credit_request_id
Ref fk_crh_from:    credit_request_history.from_status_id    > credit_request_statuses.status_id
Ref fk_crh_to:      credit_request_history.to_status_id      > credit_request_statuses.status_id
Ref fk_crh_user:    credit_request_history.changed_by        > users.user_id

// Sessions
Ref fk_sessions_user: user_sessions.user_id > users.user_id
